import { useState } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { Cpu, Zap, Coins, Clock, Brain, RefreshCw, BarChart3, Code2, LayoutGrid, CheckCircle } from 'lucide-react';

interface PromptOption {
  id: string;
  title: string;
  prompt: string;
  outputs: {
    'chatgpt-5.1': { code: string; analysis: string; stats: ModelStats };
    'gemini-3.0': { code: string; analysis: string; stats: ModelStats };
    'opus-4.5': { code: string; analysis: string; stats: ModelStats };
  };
}

interface ModelStats {
  accuracy: number;      // out of 100
  consistency: number;   // out of 100
  efficiency: number;    // tokens / scope
  latency: number;       // seconds
  cost: number;          // USD per 1M tokens
}

export default function LLMBenchmarker() {
  const [selectedPromptId, setSelectedPromptId] = useState('solidity');
  const [isEvaluating, setIsEvaluating] = useState(false);
  const [hasRun, setHasRun] = useState(false);
  const [selectedModels, setSelectedModels] = useState<string[]>(['chatgpt-5.1', 'gemini-3.0', 'opus-4.5']);

  const promptOptions: PromptOption[] = [
    {
      id: 'solidity',
      title: 'Solidity ERC-20 with Vesting',
      prompt: 'Write a gas-optimized Solidity smart contract for an ERC-20 token that includes linear vesting schedules for founders and team.',
      outputs: {
        'chatgpt-5.1': {
          code: `contract VestingToken is ERC20, Ownable {\n    struct VestingSchedule {\n        uint256 totalAmount;\n        uint256 released;\n        uint256 start;\n        uint256 duration;\n    }\n    mapping(address => VestingSchedule) public schedules;\n    // Optimized gas with unchecked increments\n}`,
          analysis: 'ChatGPT-5.1 utilizes solid inheritance structures and includes robust modifiers, but uses slightly more assembly than Gemini.',
          stats: { accuracy: 96, consistency: 94, efficiency: 88, latency: 1.8, cost: 2.50 }
        },
        'gemini-3.0': {
          code: `contract GeminiVestingToken is ERC20, Ownable {\n    // Native gas optimization via custom error declarations\n    error VestingNotStarted();\n    error ZeroAddress();\n\n    struct VestingSchedule {\n        uint128 totalAmount;\n        uint128 released;\n        uint32 start;\n        uint32 duration;\n    }\n    // Pack variables tightly to reduce storage slots (SSTORE/SLOAD)`,
          analysis: 'Gemini-3.0 achieves superior gas scores by aggressively packing structs (uint128, uint32) and using custom errors instead of require strings.',
          stats: { accuracy: 98, consistency: 96, efficiency: 95, latency: 0.9, cost: 1.25 }
        },
        'opus-4.5': {
          code: `contract ClaudeVestingToken is ERC20, Ownable {\n    // Extensively documented multi-stage safety assertions\n    // Detailed mathematical proof checks for math overflow prevention\n    using SafeERC20 for IERC20;\n    mapping(address => VestingSchedule[]) public multiSchedules;\n}`,
          analysis: 'Opus-4.5 provides the most secure implementation with defensive checks but produces long code with higher compilation gas overhead.',
          stats: { accuracy: 99, consistency: 98, efficiency: 75, latency: 3.2, cost: 8.00 }
        }
      }
    },
    {
      id: 'pandas',
      title: 'Pandas Telemetry Preprocessing',
      prompt: 'Write a Python Pandas script to clean and normalize noise in high-frequency IoT sensor telemetry containing NaN gaps.',
      outputs: {
        'chatgpt-5.1': {
          code: `import pandas as pd\nimport numpy as np\n\ndef clean_sensor_data(df):\n    df['timestamp'] = pd.to_datetime(df['timestamp'])\n    df = df.set_index('timestamp')\n    # Linear interpolation for simple gaps\n    df = df.interpolate(method='time')\n    return df`,
          analysis: 'Clean, standard functional code. Handles NaN anomalies with generic interpolation vectors.',
          stats: { accuracy: 92, consistency: 95, efficiency: 90, latency: 1.2, cost: 2.50 }
        },
        'gemini-3.0': {
          code: `import pandas as pd\nimport numpy as np\n\ndef preprocess_iot_stream(df):\n    # Vectorized outlier extraction using rolling Z-Score\n    df['timestamp'] = pd.to_datetime(df['timestamp'])\n    df.set_index('timestamp', inplace=True)\n    df['z_score'] = (df['val'] - df['val'].rolling('1H').mean()) / df['val'].rolling('1H').std()\n    df.loc[df['z_score'].abs() > 3, 'val'] = np.nan\n    return df.interpolate(method='time').bfill().ffill()`,
          analysis: 'Gemini-3.0 implements advanced time-indexed rolling Z-score detection, achieving greater accuracy in finding anomalies.',
          stats: { accuracy: 97, consistency: 95, efficiency: 92, latency: 0.7, cost: 1.25 }
        },
        'opus-4.5': {
          code: `import pandas as pd\nimport numpy as np\n\ndef clean_telemetry_series(df):\n    # Complete end-to-end framework including log files and error metrics\n    # Implements Exponential Moving Average with dynamic scaling window\n    # Includes strict structural assertions on index integrity`,
          analysis: 'Extremely detailed script, practically ready for direct production pipelines, but slower to generate due to extensive comments.',
          stats: { accuracy: 98, consistency: 97, efficiency: 80, latency: 2.6, cost: 8.00 }
        }
      }
    },
    {
      id: 'cryptography',
      title: 'Quantum Resistant Encryption',
      prompt: 'Simulate a quantum-resistant Kyber lattice key exchange algorithm in JavaScript with noise vector distribution checks.',
      outputs: {
        'chatgpt-5.1': {
          code: `class KyberSimulator {\n    constructor(k = 3) {\n        this.k = k; // Parameter set (Kyber-768)\n    }\n    generateSecretNoise() {\n        // Simulated centered binomial distribution\n    }\n}`,
          analysis: 'Implements the matrix-vector logic cleanly, though the ring polynomial multiplying logic is highly simplified.',
          stats: { accuracy: 88, consistency: 90, efficiency: 84, latency: 2.0, cost: 2.50 }
        },
        'gemini-3.0': {
          code: `class Kyber768Simulator {\n    // Native TypedArrays for high-speed linear algebra\n    constructor() {\n        this.q = 3329; // Native modulus\n        this.n = 256;  // Degree\n    }\n    // Vectorized Centered Binomial Distribution (η = 2)\n    sampleCBD(bytes) {\n        const r = new Uint16Array(this.n);\n        // Quick bit manipulation to extract random noise bits\n    }`,
          analysis: 'Highly performant implementation using JavaScript TypedArrays for fast integer arithmetic in simulated lattice structures.',
          stats: { accuracy: 94, consistency: 93, efficiency: 91, latency: 1.0, cost: 1.25 }
        },
        'opus-4.5': {
          code: `class LatticeKeyExchange {\n    // Comprehensive mathematical explanation of Module-LWE hard problem\n    // Complete simulation of ring learning with errors (R-LWE)\n    // Thorough verification of Decryption failure probabilities`,
          analysis: 'Deep, academic code outlining mathematical proofs. Incredible resource for conceptual verification, but highly verbose.',
          stats: { accuracy: 97, consistency: 98, efficiency: 70, latency: 3.5, cost: 8.00 }
        }
      }
    }
  ];

  const handleEvaluate = () => {
    setIsEvaluating(true);
    setHasRun(false);

    setTimeout(() => {
      setIsEvaluating(false);
      setHasRun(true);
    }, 1200);
  };

  const selectedPrompt = promptOptions.find(p => p.id === selectedPromptId) || promptOptions[0];

  const toggleModel = (modelId: string) => {
    if (selectedModels.includes(modelId)) {
      if (selectedModels.length > 1) {
        setSelectedModels(selectedModels.filter(m => m !== modelId));
      }
    } else {
      setSelectedModels([...selectedModels, modelId]);
    }
  };

  return (
    <div className="bg-[#0A0A0B] border border-white/10 rounded-sm overflow-hidden shadow-xl" id="llm-benchmarker-container">
      {/* Header section */}
      <div className="bg-[#070708] p-6 border-b border-white/10">
        <div className="flex flex-col md:flex-row md:items-center justify-between gap-4">
          <div>
            <div className="flex items-center gap-2">
              <Brain className="w-5 h-5 text-white/80 animate-pulse" />
              <span className="text-[10px] font-mono font-medium tracking-widest text-white/40 uppercase">
                Comparative Analysis Playground
              </span>
            </div>
            <h3 className="text-lg font-serif italic text-white mt-1 tracking-tight">
              EVM, IoT & ML Prompt Benchmarking
            </h3>
          </div>

          {/* Model selection checkers */}
          <div className="flex items-center gap-2.5 bg-[#0A0A0B] border border-white/10 p-1.5 rounded-sm text-xs font-mono">
            {[
              { id: 'chatgpt-5.1', label: 'ChatGPT-5.1', color: 'bg-white' },
              { id: 'gemini-3.0', label: 'Gemini-3.0', color: 'bg-white' },
              { id: 'opus-4.5', label: 'Opus-4.5', color: 'bg-white' }
            ].map(m => (
              <button
                key={m.id}
                onClick={() => toggleModel(m.id)}
                className={`flex items-center gap-1.5 px-3 py-1.5 rounded-sm transition-all uppercase tracking-widest text-[9px] ${
                  selectedModels.includes(m.id)
                    ? 'bg-white/5 text-white font-medium border border-white/10'
                    : 'text-white/40 hover:text-white/80 border border-transparent'
                }`}
                id={`model-chk-${m.id}`}
              >
                <span className={`w-1.5 h-1.5 rounded-full ${m.color} ${selectedModels.includes(m.id) ? 'scale-100 opacity-100' : 'scale-50 opacity-20'}`} />
                {m.label}
              </button>
            ))}
          </div>
        </div>
      </div>

      <div className="grid grid-cols-1 lg:grid-cols-12 gap-0">
        {/* Left selector and input */}
        <div className="lg:col-span-4 p-6 border-r border-white/10 bg-transparent flex flex-col gap-5">
          <div className="flex flex-col gap-1.5">
            <label className="text-[10px] font-mono text-white/40 uppercase tracking-widest font-bold">
              Select Benchmark Task
            </label>
            <div className="flex flex-col gap-2">
              {promptOptions.map((opt) => (
                <button
                  key={opt.id}
                  onClick={() => {
                    setSelectedPromptId(opt.id);
                    setHasRun(false);
                  }}
                  className={`w-full text-left p-3.5 rounded-sm border text-[10px] font-mono transition-all flex flex-col gap-1 ${
                    selectedPromptId === opt.id
                      ? 'bg-white/5 border-white/30 text-white shadow-md'
                      : 'bg-transparent border-white/10 text-white/40 hover:border-white/20 hover:text-white/80'
                  }`}
                  id={`prompt-btn-${opt.id}`}
                >
                  <span className="font-bold flex items-center gap-1.5 text-white uppercase tracking-widest">
                    <Code2 className="w-3.5 h-3.5 text-white/60" />
                    {opt.title}
                  </span>
                  <span className="truncate max-w-full text-white/40 text-[9px] mt-1">{opt.prompt}</span>
                </button>
              ))}
            </div>
          </div>

          <div className="bg-[#0A0A0B] p-4 rounded-sm border border-white/10 flex flex-col gap-2.5">
            <span className="text-[10px] font-mono text-white/40 uppercase tracking-widest font-bold">ACTIVE PROMPT</span>
            <p className="text-[11px] font-sans text-white/80 leading-relaxed italic border-l border-white/20 pl-3">
              "{selectedPrompt.prompt}"
            </p>
          </div>

          <button
            onClick={handleEvaluate}
            disabled={isEvaluating}
            className="w-full bg-white hover:bg-white/90 text-[#0A0A0B] font-medium py-2.5 px-4 rounded-sm text-[10px] tracking-[0.2em] uppercase transition-all flex items-center justify-center gap-2 mt-auto"
            id="run-benchmark-btn"
          >
            <RefreshCw className={`w-3.5 h-3.5 ${isEvaluating ? 'animate-spin' : ''}`} />
            {isEvaluating ? 'COMPILING ANALYSIS...' : 'EVALUATE LLM MODELS'}
          </button>
        </div>

        {/* Right Output Comparison panels */}
        <div className="lg:col-span-8 p-6 bg-[#0A0A0B]/50 flex flex-col justify-between min-h-[460px]">
          <AnimatePresence mode="wait">
            {isEvaluating ? (
              <motion.div
                key="eval-loading"
                initial={{ opacity: 0 }}
                animate={{ opacity: 1 }}
                exit={{ opacity: 0 }}
                className="flex-1 flex flex-col items-center justify-center gap-4 py-16 text-center"
              >
                <div className="relative">
                  <div className="w-10 h-10 rounded-full border-2 border-white/10 border-t-white animate-spin" />
                </div>
                <div>
                  <h4 className="text-[10px] font-mono tracking-widest text-white uppercase">PROMPT_VECTOR_EMBEDDING_DEPLOYED</h4>
                  <p className="text-[9px] text-white/40 uppercase tracking-widest font-mono mt-1">Comparing semantic similarity / token costs</p>
                </div>
              </motion.div>
            ) : hasRun ? (
              <motion.div
                key="eval-results"
                initial={{ opacity: 0, y: 5 }}
                animate={{ opacity: 1, y: 0 }}
                className="flex-1 flex flex-col gap-6"
              >
                {/* Visual Performance Stats Matrix */}
                <div>
                  <span className="text-[10px] font-mono text-white/40 uppercase tracking-widest font-bold">Model Benchmarks Matrix</span>
                  <div className="grid grid-cols-1 md:grid-cols-3 gap-4 mt-3">
                    {selectedModels.map((mId) => {
                      const data = selectedPrompt.outputs[mId as 'chatgpt-5.1' | 'gemini-3.0' | 'opus-4.5'];
                      if (!data) return null;
                      
                      const colorClass = mId === 'gemini-3.0' ? 'border-white/20 bg-white/5' : mId === 'chatgpt-5.1' ? 'border-white/20 bg-white/5' : 'border-white/20 bg-white/5';
                      const textClass = mId === 'gemini-3.0' ? 'text-white' : mId === 'chatgpt-5.1' ? 'text-white' : 'text-white';
                      const label = mId === 'gemini-3.0' ? 'Gemini-3.0' : mId === 'chatgpt-5.1' ? 'ChatGPT-5.1' : 'Opus-4.5';
                      
                      return (
                        <div key={mId} className={`p-4 rounded-sm border ${colorClass} font-mono flex flex-col gap-3.5`}>
                          <div className="flex justify-between items-center border-b border-white/10 pb-1.5">
                            <span className={`font-bold uppercase tracking-widest text-[10px] ${textClass}`}>{label}</span>
                            <span className="text-[8px] uppercase tracking-widest text-white/40">Fastest</span>
                          </div>

                          <div className="flex flex-col gap-2 text-[9px] uppercase tracking-widest text-white/60">
                            <div className="flex justify-between">
                              <span className="flex items-center gap-1"><Brain className="w-3 h-3 text-white/40" /> Logic Acc:</span>
                              <span className="text-white font-medium">{data.stats.accuracy}%</span>
                            </div>
                            <div className="flex justify-between">
                              <span className="flex items-center gap-1"><CheckCircle className="w-3 h-3 text-white/40" /> Consist:</span>
                              <span className="text-white font-medium">{data.stats.consistency}%</span>
                            </div>
                            <div className="flex justify-between">
                              <span className="flex items-center gap-1"><Clock className="w-3 h-3 text-white/40" /> Latency:</span>
                              <span className="text-white font-medium">{data.stats.latency}s</span>
                            </div>
                            <div className="flex justify-between">
                              <span className="flex items-center gap-1"><Coins className="w-3 h-3 text-white/40" /> Cost/1M:</span>
                              <span className="text-white font-medium">${data.stats.cost.toFixed(2)}</span>
                            </div>
                          </div>

                          {/* Simplified visually appealing score slider */}
                          <div className="flex flex-col gap-1 mt-1">
                            <span className="text-[8px] text-white/40 uppercase tracking-widest">EFFICIENCY SCORE</span>
                            <div className="w-full bg-[#0A0A0B] h-1.5 rounded-sm overflow-hidden border border-white/10">
                              <div 
                                className={`h-full rounded-sm bg-white`} 
                                style={{ width: `${data.stats.efficiency}%` }} 
                              />
                            </div>
                          </div>
                        </div>
                      );
                    })}
                  </div>
                </div>

                {/* Structured Outputs comparison code tabs */}
                <div className="flex flex-col gap-3">
                  <span className="text-[10px] font-mono text-white/40 uppercase tracking-widest font-bold">Code Synthesis comparison</span>
                  
                  <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
                    {selectedModels.map((mId) => {
                      const data = selectedPrompt.outputs[mId as 'chatgpt-5.1' | 'gemini-3.0' | 'opus-4.5'];
                      if (!data) return null;
                      const label = mId === 'gemini-3.0' ? 'Gemini-3.0' : mId === 'chatgpt-5.1' ? 'ChatGPT-5.1' : 'Opus-4.5';
                      
                      return (
                        <div key={mId} className="flex flex-col gap-2">
                          <span className="text-[9px] font-mono text-white/60 font-bold uppercase tracking-widest">{label} code:</span>
                          <pre className={`bg-[#0A0A0B] p-3 rounded-sm font-mono text-[9px] leading-relaxed text-white/80 overflow-x-auto border border-white/10 max-h-[160px]`}>
                            <code>{data.code}</code>
                          </pre>
                          <p className="text-[10px] text-white/60 font-sans leading-normal italic">
                            {data.analysis}
                          </p>
                        </div>
                      );
                    })}
                  </div>
                </div>
              </motion.div>
            ) : (
              <div className="flex-1 flex flex-col items-center justify-center text-center py-20 border border-dashed border-white/10 rounded-sm">
                <BarChart3 className="w-8 h-8 text-white/20 mb-3 animate-pulse" />
                <h4 className="text-[10px] font-mono text-white/40 uppercase tracking-widest">BENCHMARK_MODULE_AWAITING_TRIGGER</h4>
                <p className="text-[9px] text-white/30 font-mono mt-1 uppercase tracking-widest">Click "Evaluate LLM Models" to load metrics.</p>
              </div>
            )}
          </AnimatePresence>

          {/* Prompt metadata */}
          <div className="border-t border-white/10 pt-4 flex justify-between font-mono text-[9px] uppercase tracking-widest text-white/40">
            <span>LLM_MATRIX: 20+ specialized tests</span>
            <span>ACCURACY_WEIGHT: 0.40</span>
            <span>METRIC_SOURCE: Samkhya.ai benchmark dataset</span>
          </div>
        </div>
      </div>
    </div>
  );
}
